# Prevent directory listings
Options -Indexes

# Prevent visitors from viewing files directly
<Files ~ "^.*\.(sdb|md|txt)$">
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
        Satisfy All
    </IfModule>
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>

# URL rewrites
<IfModule mod_rewrite.c>
    RewriteEngine On
